{\b\fs32 2. SYSTEM ARCHITECTURE}
\par
{\fs20 2.1 HIGH-LEVEL ARCHITECTURE}
\par
{\fs20 Spectra Media Agent follows a distributed agent-based architecture:}
\par
{\fs20 ┌─────────────────────────────────────────────────────────────┐}
\par
{\fs20 │                      User Interface (Vue.js)                 │}
\par
{\fs20 └────────────────────────┬────────────────────────────────────┘}
\par
{\fs20                          │}
\par
{\fs20 ┌────────────────────────▼────────────────────────────────────┐}
\par
{\fs20 │               API Layer (Laravel/HTTP)                      │}
\par
{\fs20 ├─────────────────────────────────────────────────────────────┤}
\par
{\fs20 │  Authentication │ Campaigns │ Performance │ Admin │ Billing  │}
\par
{\fs20 └────────────────────────┬────────────────────────────────────┘}
\par
{\fs20                          │}
\par
{\fs20 ┌────────────────────────▼────────────────────────────────────┐}
\par
{\fs20 │           Core Services \\'26 Business Logic                     │}
\par
{\fs20 ├─────────────────────────────────────────────────────────────┤}
\par
{\fs20 │ Strategy   │ Performance  │ Campaign    │ Billing │ Reports  │}
\par
{\fs20 │ Generator  │ Analyzer     │ Manager     │ Service │ Service   │}
\par
{\fs20 └────────────────────────┬────────────────────────────────────┘}
\par
{\fs20                          │}
\par
{\fs20 ┌────────────────────────▼────────────────────────────────────┐}
\par
{\fs20 │          Agent Jobs (Queue-based Execution)                  │}
\par
{\fs20 ├─────────────────────────────────────────────────────────────┤}
\par
{\fs20 │ Strategy   │ Fetch       │ Deploy      │ Optimize │ Reporting│}
\par
{\fs20 │ Generation │ Performance │ Campaigns   │ Campaigns│ Agents   │}
\par
{\fs20 └────────────────────────┬────────────────────────────────────┘}
\par
{\fs20                          │}
\par
{\fs20 ┌────────────────────────▼────────────────────────────────────┐}
\par
{\fs20 │         External Platform Integrations                       │}
\par
{\fs20 ├─────────────────────────────────────────────────────────────┤}
\par
{\fs20 │ Google Ads API │ Facebook Ads API │ Stripe API │ Gemini API  │}
\par
{\fs20 └─────────────────────────────────────────────────────────────┘}
\par
{\fs20 2.2 CORE COMPONENTS}
\par
{\fs20 DATABASE LAYER:}
\par
{\fs20 - PostgreSQL with vector extensions (pgvector)}
\par
{\fs20 - Stores campaigns, performance data, strategies, and audit trails}
\par
{\fs20 - Supports multi-tenant architecture with customer isolation}
\par
{\fs20 QUEUE SYSTEM:}
\par
{\fs20 - Redis-based job queue (via Horizon)}
\par
{\fs20 - Enables asynchronous agent execution}
\par
{\fs20 - Supports job retries, timeouts, and monitoring}
\par
{\fs20 CACHE LAYER:}
\par
{\fs20 - Redis cache for performance optimization}
\par
{\fs20 - Caches API responses and computed data}
\par
