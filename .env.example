APP_NAME="Site to Spend"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sitetospend.com

# Campaign Testing Mode
# Set to true to create all campaigns as PAUSED (draft) for testing
# Set to false (or remove) for production - campaigns will be created as ENABLED
CAMPAIGN_TESTING_MODE=false
CAMPAIGN_DEFAULT_STATUS=ENABLED

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sitetospend
DB_USERNAME=postgres
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sfo3
AWS_BUCKET=sitetospend
AWS_ENDPOINT=https://sfo3.digitaloceanspaces.com
AWS_URL=https://sitetospend.sfo3.cdn.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Cloudflare Turnstile (Bot Detection)
# Get your keys from: https://dash.cloudflare.com/?to=/:account/turnstile
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────
# Stripe (Billing & Subscriptions)
# ─────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret — create at: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# Metered ad-spend billing price ID (create a metered price in Stripe)
STRIPE_AD_SPEND_PRICE_ID=

# ─────────────────────────────────────────────────
# Google OAuth (User Login via Google)
# ─────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────
# Google Ads (MCC Management Account)
# ─────────────────────────────────────────────────
# Your Manager (MCC) account customer ID (no dashes, e.g. 1234567890)
GOOGLE_ADS_MCC_CUSTOMER_ID=
# Refresh token generated for the MCC account
GOOGLE_ADS_MCC_REFRESH_TOKEN=
# Set to true to use the test account (no real spend)
GOOGLE_ADS_USE_TEST_ACCOUNT=false

# ─────────────────────────────────────────────────
# Google Gemini AI
# ─────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────
# Google Cloud (Service Account for Vertex AI, etc.)
# ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# ─────────────────────────────────────────────────
# Google Custom Search API (Competitor Discovery)
# ─────────────────────────────────────────────────
# Create at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ─────────────────────────────────────────────────
# Facebook Ads (Platform Business Manager — System User)
# ─────────────────────────────────────────────────
# Create app at: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Facebook Login Configuration ID (optional, for config-based login)
FACEBOOK_CONFIG_ID=
# Business Manager ID — create at: https://business.facebook.com/
FACEBOOK_BUSINESS_MANAGER_ID=
# System User token — generate at: Business Settings → System Users → Generate Token
# Must have ads_management, business_management, pages_manage_ads scopes
FACEBOOK_SYSTEM_USER_TOKEN=
# Platform Facebook Page ID used as publisher for all customer campaigns
FACEBOOK_PAGE_ID=

# ─────────────────────────────────────────────────
# Microsoft Ads (Manager Account)
# ─────────────────────────────────────────────────
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_TENANT_ID=common
MICROSOFT_ADS_DEVELOPER_TOKEN=
MICROSOFT_ADS_REFRESH_TOKEN=
# Your Manager (MCC) account ID
MICROSOFT_ADS_MANAGER_ACCOUNT_ID=
MICROSOFT_ADS_ENVIRONMENT=production

# ─────────────────────────────────────────────────
# LinkedIn Ads (Management Account)
# ─────────────────────────────────────────────────
# Create app at: https://www.linkedin.com/developers/
LINKEDIN_ADS_CLIENT_ID=
LINKEDIN_ADS_CLIENT_SECRET=
LINKEDIN_ADS_REFRESH_TOKEN=
LINKEDIN_ADS_API_VERSION=202404

# ─────────────────────────────────────────────────
# Google Tag Manager (Platform-Managed)
# ─────────────────────────────────────────────────
# Refresh token for the platform's Google account with GTM edit+publish scopes
GTM_PLATFORM_REFRESH_TOKEN=
# GTM Account ID under which per-customer containers are created
GTM_PLATFORM_ACCOUNT_ID=

# ─────────────────────────────────────────────────
# Third-Party Services
# ─────────────────────────────────────────────────
# Firecrawl — web scraping for knowledge base
FIRECRAWL_API_KEY=
# Moz — domain authority metrics
MOZ_API_KEY=
